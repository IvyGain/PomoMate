# Development Environment for Expo Go
# このファイルを.envにコピーして使用してください

# APIエンドポイント（ローカルIP使用）
# 注意: localhostではなく、あなたのマシンのローカルIPアドレスを使用してください
# 例: 192.168.1.100
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3000/api

# WebSocket URL
EXPO_PUBLIC_WS_URL=ws://YOUR_LOCAL_IP:3000

# 開発モード
EXPO_PUBLIC_ENV=development

# その他の開発設定
EXPO_PUBLIC_DEBUG=true